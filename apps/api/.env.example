# ==========================================
# InstaAI - Backend Environment Variables
# ==========================================

# Port Configuration
PORT=4000
NODE_ENV=development

# Database Connection (PostgreSQL)
# Adjust username, password, host, port, and database name as necessary
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/instagram_ai_dev?schema=public

# Redis Connection (BullMQ queues)
REDIS_URL=redis://localhost:6379

# Clerk JWT Auth Guard Configuration
# Replace <your-clerk-domain> with your actual Clerk project domain
CLERK_JWKS_URI=https://clerk.yourdomain.com/.well-known/jwks.json
CLERK_ISSUER=https://clerk.yourdomain.com

# Enable/Disable local JWT validation bypass (ONLY for development/testing)
BYPASS_AUTH=true

# Security Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# AWS S3 Configuration (Reserved for future uploads)
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_S3_BUCKET_NAME=your-s3-bucket-name
AWS_REGION=us-east-1
