# ==========================================
# InstaAI - Backend Environment Variables Example
# Copy this to .env and fill in real values
# ==========================================

# Port Configuration
PORT=4000
NODE_ENV=development

# Database Connection (PostgreSQL via docker-compose)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/instagram_ai_dev?schema=public

# Redis Connection (BullMQ queues via docker-compose)
REDIS_URL=redis://localhost:6379

# Clerk JWT Auth Guard
# Get from: https://dashboard.clerk.com → Your App → API Keys
CLERK_JWKS_URI=https://your-app.clerk.accounts.dev/.well-known/jwks.json
CLERK_ISSUER=https://your-app.clerk.accounts.dev

# Development bypass — set to true ONLY in local dev, never in production
BYPASS_AUTH=true

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Token Encryption Key (AES-256-GCM) — REQUIRED
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=GENERATE_A_RANDOM_64_HEX_CHAR_STRING_HERE

# ==========================================
# Meta / Instagram API Credentials
# ==========================================
# Get from: https://developers.facebook.com/apps → Your App → Settings → Basic
META_APP_ID=YOUR_META_APP_ID
META_APP_SECRET=YOUR_META_APP_SECRET
META_REDIRECT_URI=http://localhost:4000/api/instagram/callback
FRONTEND_SETTINGS_URL=http://localhost:3000/settings

# ==========================================
# AWS S3 (Media Uploads)
# ==========================================
# Get from: https://console.aws.amazon.com/iam → Users → Security credentials
# If placeholders are set, local disk storage is used as fallback automatically.
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_S3_BUCKET_NAME=your-s3-bucket-name
AWS_REGION=us-east-1

# ==========================================
# Stripe Billing (Phase 5 — not yet wired)
# ==========================================
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_STRIPE_WEBHOOK_SECRET
